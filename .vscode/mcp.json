{
	"servers": {
		"deepgram": {
			"url": "https://deepgram.mcp.kapa.ai",
			"type": "http"
		},
		"mysql": {
			"type": "stdio",
			"command": "uvx",
			"args": [
				"--from",
				"mysql-mcp-server",
				"mysql_mcp_server"
			],
			"env": {
				"MYSQL_HOST": "localhost",
				"MYSQL_PORT": "3306",
				"MYSQL_USER": "root",
				"MYSQL_PASSWORD": "root",
				"MYSQL_DATABASE": "customer_support_db"
			}
		},
		"github": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-github"
			],
			"env": {
				"GITHUB_TOKEN": "${env:GITHUB_TOKEN}"
			}
		}
	},
	"inputs": []
}